<UserControl x:Class="FastHotKeyForWPF.HotKeyBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FastHotKeyForWPF"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="#1e1e1e" Foreground="Cyan">
    <UserControl.Template>
        <ControlTemplate>
            <Border ClipToBounds="True" 
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{Binding CornerRadius,RelativeSource={RelativeSource AncestorType=local:HotKeyBox}}">
                <Grid>
                    <TextBox PreviewKeyDown="OnHotKeyReceived"
                         MouseEnter="TextBox_MouseEnter"
                         MouseLeave="TextBox_MouseLeave"
                         IsReadOnly="True"
                         Background="Transparent"/>
                    <TextBlock Text="{Binding Text, RelativeSource={RelativeSource AncestorType=local:HotKeyBox}}" 
                           Foreground="{TemplateBinding Foreground}" 
                           FontSize="{TemplateBinding FontSize}"
                           Background="Transparent"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>
                </Grid>
            </Border>
        </ControlTemplate>
    </UserControl.Template>
</UserControl>
